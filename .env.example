# Google Maps Platform API Key
# Enable "Map Tiles API" in Google Cloud Console: https://console.cloud.google.com/
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Cesium Ion Access Token
# Get a free token at: https://ion.cesium.com/tokens
VITE_CESIUM_ION_TOKEN=your_cesium_ion_token_here

# Firebase Auth (client-side)
# Get these from Firebase Console → Project Settings → General → Your apps → Web app
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# OpenSky Network credentials are now server-side only (Firebase Cloud Functions).
# Set them via: firebase functions:secrets:set OPENSKY_CLIENT_ID
#               firebase functions:secrets:set OPENSKY_CLIENT_SECRET
